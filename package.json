{
  "name": "trier-fantasy",
  "private": true,
  "version": "3.3.1",
  "type": "module",
  "scripts": {
    "dev": "node scripts/generate_build_info.js && vite",
    "build": "node scripts/generate_build_info.js && tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test:unit": "node --import tsx/esm --test tests/unit/*.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "stats:fetch": "node scripts/fetch_official_stats.js",
    "stats:fetch:dry": "node scripts/fetch_official_stats.js --dry-run",
    "stats:rollover": "node scripts/rollover_season.js",
    "player:refresh": "node scripts/refresh_player_pool.js",
    "player:diff": "node scripts/refresh_player_pool.js --diff-only"
  },
  "dependencies": {
    "@tauri-apps/api": "^1.6.0",
    "framer-motion": "^12.29.0",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.563.0",
    "qrcode.react": "^4.2.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-to-print": "^3.2.0",
    "react-twitter-embed": "^4.0.4",
    "react-youtube": "^10.1.0",
    "recharts": "^3.8.1",
    "simple-peer": "^9.11.1",
    "trystero": "^0.23.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^1.6.3",
    "@types/node": "^25.6.0",
    "@types/qrcode.react": "^1.0.5",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/react-youtube": "^7.6.2",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.3.1",
    "vite-plugin-node-polyfills": "^0.25.0"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  }
}
